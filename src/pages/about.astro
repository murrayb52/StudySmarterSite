---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="About"
  description="James Buchanan is a school principal, past national examiner, and author of Study Smarter — a research-backed guide for high school students."
>
  <Nav slot="nav" />
  <Footer slot="footer" />

  <section class="about-section">

    <div class="author-photo-col">
      <img
        src="/images/019-999-IMG_5473-Enhanced-NR.jpg"
        alt="James Buchanan speaking at the Study Smarter book launch"
        loading="eager"
      />
    </div>

    <div class="author-bio-col">
      <span class="eyebrow">About the author</span>
      <h1 style="font-weight:600">James Buchanan</h1>

      <p>
        James Buchanan is a school principal and past national examiner who has spent over thirty years
        in education as a teacher in the sciences. He holds a BSc (Hons) in Biology and an MEd in
        self-regulated learning, and is currently working towards a PhD in study skills.
      </p>
      <p>
        James has an enduring passion for helping students find fulfilment in their schoolwork and
        success in learning. He lives in Cape Town with his wife, and has two grown children.
        <em>Study Smarter</em> is his second book.
      </p>

      <div class="author-credentials">
        <span class="credential">BSc (Hons) in Biology</span>
        <span class="credential">MEd in self-regulated learning</span>
        <span class="credential">PhD candidate in study skills</span>
        <span class="credential">School principal</span>
        <span class="credential">Past national examiner</span>
        <span class="credential">30+ years in education</span>
      </div>

      <a href="/shop" class="btn btn-primary">Get the book</a>
    </div>

  </section>
</Base>

<style>
  .about-section {
    display: grid;
    grid-template-columns: 420px 1fr;
    grid-template-rows: minmax(calc(100vh - 64px), auto);
  }

  .author-photo-col {
    position: relative;
    overflow: hidden;
  }
  .author-photo-col img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .author-bio-col {
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 680px;
  }
  .author-bio-col .btn {
    align-self: flex-start;
  }

  .author-bio-col h1 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 1.5rem;
  }

  .author-bio-col p {
    color: var(--c-text-muted);
    font-size: 1.0625rem;
    max-width: 54ch;
  }

  .author-bio-col em { font-style: normal; font-weight: 600; }

  .author-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.75rem 0 2rem;
  }
  .credential {
    background: var(--c-surface);
    border: 1px solid #d8d4cf;
    border-radius: 100px;
    padding: 0.4rem 1rem;
    font-size: 0.875rem;
    color: var(--c-text);
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .about-section {
      grid-template-columns: 1fr;
      min-height: unset;
    }
    .author-photo-col {
      position: relative;
      height: 55vw;
      max-height: 420px;
    }
    .author-bio-col {
      padding: 3rem 1.5rem;
    }
  }
</style>
