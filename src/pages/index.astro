---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BookCard from '../components/BookCard.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Study Smarter"
  description="A practical, research-backed book for high school students — and everyone who supports them. By James Buchanan, Cape Town."
>
  <Nav slot="nav" />
  <Footer slot="footer" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true" style={`background-image: url('${b}/images/fishbowl-leap-wide.png')`}></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="eyebrow">Written by an educator. Built for students.</span>
        <h1>
          <span class="strong">Study smarter,</span>
          <span class="soft">not harder.</span>
        </h1>
        <p class="hero-lead">
          The vital but too-often neglected skill — how to study properly.
          Not tips. A complete, teachable method grounded in thirty years in the classroom.
        </p>
        <div class="hero-ctas">
          <a href={`${b}/shop`} class="btn btn-primary">Shop Now</a>
          <a href={`${b}/resources`} class="btn btn-outline">Free Resources</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who is this for -->
  <section class="audience">
    <div class="audience-text">
      <span class="eyebrow audience-eyebrow">Who is this for?</span>
      <h2 class="audience-heading"><span style="font-weight:600">This book is about to</span><br><span style="font-weight:300">change everything.</span></h2>
      <p class="audience-intro">Are you&hellip;</p>
      <ul class="audience-list">
        <li>a parent shaping your child's first (or later) steps in studying</li>
        <li>a teacher with a heart for supporting your students' efforts</li>
        <li>in school management and wanting to make meaningful changes</li>
        <li>a tertiary student wanting to reshape school habits that no longer cut it?</li>
      </ul>
      <p class="audience-close">Then this is the book for you.</p>
    </div>
    <div class="audience-photo" style={`background-image: url('${b}/images/bg-goldfish-pattern.png')`}>
      <img src={`${b}/images/book-cover.png`} alt="Study Smarter book cover" loading="lazy" />
    </div>
  </section>

  <!-- About the books -->
  <section class="section about-books">
    <div class="about-books-pattern" aria-hidden="true" style={`background-image: url('${b}/images/bg-goldfish-pattern.png')`}></div>
    <div class="container">
      <span class="eyebrow">The books</span>
      <h2><span style="font-weight:600">One method.</span> <span style="font-weight:300">Two formats.</span></h2>
      <p class="about-lead">
        <em>Study Smarter</em> gives students a clear, structured approach to learning — not a list of tips, but a complete
        method developed over thirty years in the classroom and grounded in the science of self-regulated learning.
        The companion Student Workbook takes students systematically through those principles, putting theory into practice
        with perforated pages designed to be torn out and pasted into notebooks.
      </p>
    </div>
  </section>

  <!-- Featured book -->
  <section class="section section-alt product-section">
    <div class="container">

      <div class="product-featured">
        <BookCard
          featured={true}
          title="Study Smarter"
          description="Evidence-based strategies for high school students. Covers planning, memory, focus, exam technique, and the mindset shifts that make it all stick — not as a list of tips, but as a complete, teachable method grounded in the science of self-regulated learning."
          coverSrc="/images/book-cover.png"
          coverAlt="Study Smarter book cover"
          price="R350"
          buyHref="/shop"
          buyLabel="Buy Now"
        />
      </div>

      <div class="product-secondary">
        <h3 class="secondary-heading">
          <span style="font-weight:600">Also available:</span>
          <span style="font-weight:300"> The Student Workbook</span>
        </h3>
        <BookCard
          title="Study Smarter Student Workbook"
          description="This A4, full-colour workbook is a companion to Study Smarter and takes students systematically through the principles shared in the book. Here they get to put theory into practice."
          coverSrc="/images/workbook-cover.png"
          coverAlt="Study Smarter Student Workbook cover"
          note="Can be used as-is, or tear out the perforated pages and paste them into your student notebooks."
          previewUrl="https://s3.af-south-1.amazonaws.com/mags.digimaghost.com/StudySmarterStudentWorkbook.html"
          price="R270"
          buyHref="/shop"
          buyLabel="Shop Now"
        />
      </div>

    </div>
  </section>

  <!-- Author teaser -->
  <section class="author-teaser">
    <div class="author-teaser-photo">
      <img
        src={`${b}/images/james-speaking-gesturing.jpg`}
        alt="James Buchanan speaking at the Study Smarter book launch"
        loading="lazy"
      />
    </div>
    <div class="author-teaser-content">
      <div class="author-teaser-text">
        <span class="eyebrow">The author</span>
        <h2 style="font-weight:600">James Buchanan</h2>
        <p>
          School principal, past national examiner, and MEd graduate in self-regulated learning —
          James has spent over thirty years helping students find success in learning, not just in exams.
        </p>
        <a href={`${b}/about`} class="btn btn-outline">Read more</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 5rem 0 5rem;
    overflow: hidden;
    min-height: 560px;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: auto 130%;
    background-position: -400px 85%;
    background-repeat: no-repeat;
    z-index: 0;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      transparent 0px,
      transparent 490px,
      rgba(250,250,248,0.72) 620px,
      var(--c-bg) 750px,
      var(--c-bg) 100%
    );
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }
  .hero-text {
    margin-left: 510px;
    flex: 1;
    padding-right: clamp(2rem, 5vw, 6rem);
  }
  .hero-text h1 {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    line-height: 1.08;
    margin: 0.5rem 0 1.25rem;
  }
  .strong { font-weight: 600; display: block; }
  .soft { font-weight: 300; display: block; }
  .hero-lead {
    font-size: 1.125rem;
    color: var(--c-text-muted);
    max-width: 58ch;
    margin-bottom: 2rem;
  }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Audience */
  .audience {
    display: grid;
    grid-template-columns: 1fr 420px;
    min-height: 480px;
  }
  .audience-photo {
    overflow: hidden;
    background-color: #e2ddd8;
    background-size: 380px auto;
    background-position: center;
    background-repeat: repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2.5rem;
  }
  .audience-photo img {
    max-width: 100%;
    max-height: 400px;
    width: auto;
    height: auto;
    display: block;
    box-shadow: 0 16px 52px rgba(0,0,0,0.38);
    border-radius: 2px;
  }
  .audience-text {
    background: #1c2a35;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .audience-eyebrow {
    color: rgba(255, 255, 255, 0.5) !important;
    display: block;
    margin-bottom: 0.5rem;
  }
  .audience-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 1.25rem;
    color: var(--c-accent);
    line-height: 1.15;
  }
  .audience-intro {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 0.5rem;
  }
  .audience-list {
    margin: 0 0 1.5rem 1.25rem;
    padding: 0;
    color: rgba(255,255,255,0.82);
    font-size: 1.0625rem;
    line-height: 2.1;
  }
  .audience-list li { padding-left: 0.25rem; }
  .audience-close {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.375rem;
    color: var(--c-accent);
    margin: 0;
  }

  /* About the books */
  .about-books {
    position: relative;
    overflow: hidden;
  }
  .about-books-pattern {
    position: absolute;
    inset: 0;
    background-size: 480px auto;
    background-repeat: repeat;
    opacity: 0.38;
    z-index: 0;
    pointer-events: none;
  }
  .about-books .container {
    position: relative;
    z-index: 1;
  }
  .about-books h2 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin: 0.5rem 0 1rem;
  }
  .about-lead {
    max-width: 62ch;
    color: var(--c-text-muted);
    font-size: 1.0625rem;
  }
  .about-lead em { font-style: normal; font-weight: 600; }

  /* Product section */
  .product-featured {
    margin-bottom: 3rem;
  }
  .secondary-heading {
    font-family: var(--f-serif);
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    color: var(--c-text-muted);
  }
  .product-secondary {
    max-width: 480px;
  }

  /* Author teaser */
  .author-teaser {
    display: grid;
    grid-template-columns: 340px 1fr;
    min-height: 380px;
    background: var(--c-surface);
  }
  .author-teaser-photo {
    overflow: hidden;
  }
  .author-teaser-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .author-teaser-content {
    display: flex;
    align-items: center;
    padding: 3.5rem;
  }
  .author-teaser-text h2 {
    font-size: 1.875rem;
    margin: 0.5rem 0 1rem;
  }
  .author-teaser-text p {
    color: var(--c-text-muted);
    max-width: 46ch;
    margin-bottom: 1.75rem;
  }

  @media (max-width: 768px) {
    .hero { min-height: 420px; padding: 3.5rem 0; }
    .hero-bg { background-position: center top; }
    .hero-bg::after {
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(250,250,248,0.75) 38%,
        var(--c-bg) 58%,
        var(--c-bg) 100%
      );
    }
    .hero-inner { justify-content: flex-start; }
    .hero-text { margin-left: 0; padding-right: 0; padding-left: 1.5rem; }
    .audience {
      grid-template-columns: 1fr;
    }
    .audience-photo {
      height: 340px;
    }
    .audience-text {
      padding: 2.5rem 1.5rem;
    }
    .product-secondary { max-width: 100%; }
    .author-teaser {
      grid-template-columns: 1fr;
    }
    .author-teaser-photo {
      height: 320px;
    }
    .author-teaser-content {
      padding: 2rem 1.5rem;
    }
  }
</style>
