---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DownloadCard from '../components/DownloadCard.astro';
const base = import.meta.env.BASE_URL;
---

<Base
  title="Free Resources"
  description="Free study tools from The Study Smarter Hub — download the exam planner, workbook guide, and teacher reflection guide."
>
  <Nav slot="nav" />
  <Footer slot="footer" />

  <section class="resources-header">
    <div class="resources-header-bg" aria-hidden="true" style={`background-image: url('${base}images/bg-notebook-flatlay.png')`}></div>
    <div class="container resources-header-inner">
      <span class="eyebrow">For students, parents &amp; teachers</span>
      <h1 style="font-weight:600">Free study tools</h1>
      <p class="resources-intro">
        A set of resources to support students and educators — free to download, ready to use.
      </p>
    </div>
  </section>

  <section class="section resources-cards">
    <div class="container">
      <div class="download-grid">

        <DownloadCard
          title="Study Planner Exam Template"
          fileType="XLS"
          downloadHref="/downloads/StudySmarter - study-planner-exam-template.xlsx"
          coverSrc="/images/resource-study-planner.png"
          coverAlt="Study Planner Exam Template illustration"
          horizontal={true}
        >
          <p class="resource-lead">Need help creating a study calendar?</p>
          <p class="resource-body">Well-planned studying means you know how much time you have, face challenges head-on, and can enjoy your free time guilt-free.</p>
        </DownloadCard>

        <DownloadCard
          title="Student Workbook Guide"
          fileType="PDF"
          downloadHref="/downloads/StudySmarter - workbook-answers-and-guide.pdf"
          coverSrc="/images/resource-workbook-guide.png"
          coverAlt="Student Workbook Guide illustration"
          horizontal={true}
        >
          <p class="resource-lead">Answers and coaching advice for parents</p>
          <p class="resource-body">Full answers to every workbook question, guidance on how to coach your student through each section, and links to useful resources — so you can support the process confidently.</p>
        </DownloadCard>

        <DownloadCard
          title="Teacher Reflection Guide"
          fileType="PDF"
          downloadHref="/downloads/StudySmarter - What can teachers do to support studying.pdf"
          coverSrc="/images/resource-teacher-guide.png"
          coverAlt="Teacher Reflection Guide illustration"
          horizontal={true}
        >
          <p class="resource-lead">A self-assessment for teachers</p>
          <p class="resource-body">Rate yourself across eight classroom practices — from how you set homework to how you support notebook use. Takes minutes; the reflection it prompts is lasting.</p>
        </DownloadCard>

      </div>
    </div>
  </section>  <!-- /resources-cards -->
</Base>

<style>
  /* Header section with notebook background */
  .resources-header {
    position: relative;
    overflow: hidden;
    padding: 4.5rem 0 3.5rem;
  }
  .resources-header-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  .resources-header-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250,250,248,0.82);
  }
  .resources-header-inner {
    position: relative;
    z-index: 1;
  }

  .resources-intro {
    max-width: 52ch;
    color: var(--c-text-muted);
    margin-bottom: 0;
    font-size: 1.0625rem;
  }
  .download-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  :global(.resource-lead) {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--c-text);
    margin: 0 0 0.4rem;
  }
  :global(.resource-body) {
    color: var(--c-text-muted);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.65;
  }

</style>
