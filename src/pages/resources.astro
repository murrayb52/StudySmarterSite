---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DownloadCard from '../components/DownloadCard.astro';
---

<Base
  title="Free Resources"
  description="Free study tools from The Study Smarter Hub — download the exam planner, workbook guide, and teacher reflection guide."
>
  <Nav slot="nav" />
  <Footer slot="footer" />

  <section class="section">
    <div class="container">
      <span class="eyebrow">For students, parents &amp; teachers</span>
      <h1 style="font-weight:600">Free study tools</h1>
      <p class="resources-intro">
        A set of resources to support students and educators — free to download, ready to use.
      </p>

      <div class="download-stack">

        <DownloadCard
          title="Study Planner Exam Template"
          fileType="XLS"
          downloadHref="/downloads/StudySmarter - study-planner-exam-template.xlsx"
        >
          <p class="resource-lead">Need help creating a study calendar?</p>
          <p class="resource-body">Well-planned studying means&hellip;</p>
          <ul class="resource-list">
            <li>you know how much you have to study far enough ahead to deal with things that go wrong</li>
            <li>you know you have the time to do everything you wanted — confidence up; anxiety down</li>
            <li>you face your challenges (good!) rather than trying to run away from them (bad!)</li>
            <li>you know when you have to work, and when you can enjoy your free time guilt- and worry-free</li>
          </ul>
          <p class="resource-body">Click download to get the Excel template, adapt it to your needs, and start planning the smarter way.</p>
        </DownloadCard>

        <DownloadCard
          title="Student Workbook Guide"
          fileType="PDF"
          downloadHref="/downloads/StudySmarter - workbook-answers-and-guide.pdf"
        >
          <p class="resource-lead">Guidance for completing the Student Workbook</p>
          <p class="resource-body">
            The Study Smarter Student Workbook is designed as a starting point, with perforated pages to help
            you organise your learning. Tear out each page, paste it into your notebook, and use the extra
            space for answers or additional resources.
          </p>
          <p class="resource-body">In this guide you will find:</p>
          <ul class="resource-list">
            <li>Comprehensive solutions to Student Workbook questions</li>
            <li>Practical advice to support and guide your student</li>
            <li>Links to useful tools and references</li>
            <li>Suggestions for pacing and expanding on key topics</li>
            <li>A step-by-step approach to structuring learning effectively</li>
          </ul>
        </DownloadCard>

        <DownloadCard
          title="Teacher Reflection Guide"
          fileType="PDF"
          downloadHref="/downloads/StudySmarter - What can teachers do to support studying.pdf"
        >
          <p class="resource-lead">What can teachers do to support studying?</p>
          <p class="resource-body">
            Supporting studying doesn't require you to lose class time. Reflect on how well you're doing
            at supporting your students while making only minor adjustments to what you do. Small changes;
            big differences.
          </p>
        </DownloadCard>

      </div>
    </div>
  </section>
</Base>

<style>
  .resources-intro {
    max-width: 52ch;
    color: var(--c-text-muted);
    margin-bottom: 3rem;
    font-size: 1.0625rem;
  }
  .download-stack {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 820px;
  }

  /* Slotted content styles (scoped via :global because content comes from slot) */
  :global(.resource-lead) {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--c-text);
    margin: 0 0 0.5rem;
  }
  :global(.resource-body) {
    color: var(--c-text-muted);
    font-size: 1rem;
    margin: 0 0 0.75rem;
  }
  :global(.resource-list) {
    color: var(--c-text-muted);
    font-size: 1rem;
    margin: 0 0 0.75rem 1.25rem;
    padding: 0;
    line-height: 1.9;
  }
  :global(.resource-list li) { padding-left: 0.25rem; }
</style>
