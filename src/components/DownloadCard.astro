---
export interface Props {
  title: string;
  description?: string;
  fileType: 'PDF' | 'XLS';
  downloadHref?: string;
  comingSoon?: boolean;
}

const { title, description, fileType, downloadHref, comingSoon = false } = Astro.props;
---

<div class:list={['download-card', `type-${fileType.toLowerCase()}`, { 'coming-soon': comingSoon }]}>
  <div class="card-top">
    <span class={`file-badge file-badge--${fileType.toLowerCase()}`}>{fileType}</span>
    <h3>{title}</h3>
  </div>
  <div class="card-content">
    {description && <p class="dl-desc">{description}</p>}
    <slot />
  </div>
  <div class="dl-action">
    {comingSoon
      ? <span class="badge-coming-soon">Coming soon</span>
      : downloadHref
        ? (
          <a href={downloadHref} download class="btn btn-primary dl-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download
          </a>
        )
        : null
    }
  </div>
</div>

<style>
  .download-card {
    background: var(--c-surface);
    border-radius: 12px;
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 6px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.07);
    border-left: 4px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .download-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 44px rgba(0,0,0,0.16), 0 4px 12px rgba(0,0,0,0.09);
  }
  .type-xls { border-left-color: var(--c-nav); }
  .type-pdf { border-left-color: var(--c-accent); }
  .coming-soon { opacity: 0.7; }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .card-top h3 {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.5rem;
    margin: 0;
    color: var(--c-text);
  }

  .file-badge {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .file-badge--pdf { background: #f0d0c8; color: #8b2e12; }
  .file-badge--xls { background: #d0dde6; color: #2e4a5c; }

  .card-content {
    flex: 1;
  }
  .dl-desc {
    color: var(--c-text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .dl-action { margin-top: 0.25rem; }

  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge-coming-soon {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text-muted);
    background: #e0dcd7;
    border-radius: 4px;
    padding: 0.35rem 0.75rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
</style>
