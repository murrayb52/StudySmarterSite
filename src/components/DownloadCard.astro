---
export interface Props {
  title: string;
  description?: string;
  fileType: 'PDF' | 'XLS';
  downloadHref?: string;
  comingSoon?: boolean;
  coverSrc?: string;
  coverAlt?: string;
}

const { title, description, fileType, downloadHref, comingSoon = false, coverSrc, coverAlt } = Astro.props;
---

<div class:list={['download-card', { 'coming-soon': comingSoon }]}>
  <div class="card-cover">
    {coverSrc
      ? <img src={coverSrc} alt={coverAlt ?? title} loading="lazy" />
      : <div class="cover-placeholder" aria-hidden="true">
          <span class="placeholder-label">{title.split(' ').slice(0, 2).join(' ')}</span>
        </div>
    }
    <span class={`file-badge file-badge--${fileType.toLowerCase()}`}>{fileType}</span>
  </div>
  <div class="card-info">
    <h3>{title}</h3>
    {description && <p class="dl-desc">{description}</p>}
    <div class="card-content">
      <slot />
    </div>
    <div class="dl-action">
      {comingSoon
        ? <span class="badge-coming-soon">Coming soon</span>
        : downloadHref
          ? (
            <a href={downloadHref} download class="btn btn-primary dl-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download
            </a>
          )
          : null
      }
    </div>
  </div>
</div>

<style>
  .download-card {
    background: var(--c-surface);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 6px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.07);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .download-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 44px rgba(0,0,0,0.16), 0 4px 12px rgba(0,0,0,0.09);
  }
  .download-card.coming-soon { opacity: 0.72; }

  /* Cover area — mirrors BookCard's .book-cover */
  .card-cover {
    background: #e2ddd8 url('/images/bg-goldfish-pattern.png') center/380px auto repeat;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2.5rem 2rem;
    min-height: 220px;
    position: relative;
  }
  .card-cover img {
    max-height: 260px;
    width: auto;
    display: block;
    box-shadow: 0 8px 28px rgba(0,0,0,0.22);
    border-radius: 2px;
  }

  /* Placeholder shown when no image provided */
  .cover-placeholder {
    width: 160px;
    height: 200px;
    background: var(--c-surface);
    border: 2px dashed #c0bab4;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
  }
  .placeholder-label {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 0.875rem;
    color: #a09890;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* File badge overlaid on cover */
  .file-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
  .file-badge--pdf { background: #f0d0c8; color: #8b2e12; }
  .file-badge--xls { background: #d0dde6; color: #2e4a5c; }

  /* Info area — mirrors BookCard's .book-info */
  .card-info {
    padding: 1.75rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-info h3 {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--c-text);
  }
  .dl-desc {
    color: var(--c-text-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.75rem;
  }
  .card-content {
    flex: 1;
  }
  .dl-action { margin-top: 1.25rem; }

  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .badge-coming-soon {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text-muted);
    background: #e0dcd7;
    border-radius: 4px;
    padding: 0.35rem 0.75rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
</style>
