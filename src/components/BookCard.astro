---
export interface Props {
  title: string;
  description: string;
  coverSrc: string;
  coverAlt: string;
  price?: string;
  amazonUrl?: string;
  buyHref?: string;
  buyLabel?: string;
  comingSoon?: boolean;
  note?: string;
  previewUrl?: string;
  featured?: boolean;
}

const {
  title,
  description,
  coverSrc,
  coverAlt,
  price,
  amazonUrl,
  buyHref,
  buyLabel = 'Buy Now',
  comingSoon = false,
  note,
  previewUrl,
  featured = false,
} = Astro.props;
---

<div class:list={['book-card', { featured }]}>
  <div class="book-cover">
    <img src={coverSrc} alt={coverAlt} loading="lazy" />
  </div>
  <div class="book-info">
    <h3>{title}</h3>
    <p class="book-desc">{description}</p>
    {note && <p class="book-note">{note}</p>}
    {previewUrl && (
      <a href={previewUrl} target="_blank" rel="noopener noreferrer" class="preview-link">
        Preview inside ↗
      </a>
    )}
    <div class="book-price">
      {comingSoon
        ? <span class="badge-coming-soon">Price coming soon</span>
        : price
          ? <span class="price">{price}</span>
          : null
      }
    </div>
    <div class="book-cta">
      {comingSoon
        ? null
        : amazonUrl
          ? <a href={amazonUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              {buyLabel} ↗
            </a>
          : buyHref
            ? <a href={buyHref} class="btn btn-primary">{buyLabel}</a>
            : <button type="button" class="btn btn-primary buy-trigger" data-product={title}>
                {buyLabel}
              </button>
      }
    </div>
  </div>
</div>

<style>
  .book-card {
    background: var(--c-surface);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 6px 28px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.07);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .book-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 44px rgba(0,0,0,0.16), 0 4px 12px rgba(0,0,0,0.09);
  }
  .book-card.featured {
    flex-direction: row;
    align-items: stretch;
  }
  .book-cover {
    background: #e2ddd8 url('/images/bg-goldfish-pattern.png') center/380px auto repeat;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2.5rem 2rem;
    flex-shrink: 0;
  }
  .book-card.featured .book-cover {
    min-width: 280px;
    max-width: 320px;
    padding: 3rem 2.5rem;
    align-self: stretch;
    align-items: center;
  }
  .book-cover img {
    max-height: 340px;
    width: auto;
    box-shadow: 0 8px 32px rgba(0,0,0,0.28);
    border-radius: 2px;
  }
  .book-card.featured .book-cover img {
    max-height: 520px;
    width: 100%;
    object-fit: contain;
  }
  .book-info {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .book-info h3 {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }
  .book-card.featured .book-info h3 {
    font-size: 1.875rem;
    margin-bottom: 0.75rem;
  }
  .book-desc {
    color: var(--c-text-muted);
    font-size: 0.9375rem;
    flex: 1;
    margin-bottom: 0.75rem;
  }
  .book-note {
    font-size: 0.875rem;
    color: var(--c-text-muted);
    border-left: 2px solid var(--c-blue);
    padding-left: 0.75rem;
    margin-bottom: 1rem;
  }
  .preview-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-blue);
    display: inline-block;
    margin-bottom: 1.25rem;
    text-decoration: none;
  }
  .preview-link:hover { text-decoration: underline; }
  .book-price {
    margin-bottom: 1rem;
  }
  .price {
    font-family: var(--f-serif);
    font-weight: 600;
    font-size: 1.375rem;
    color: var(--c-text);
  }
  .badge-coming-soon {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text-muted);
    background: #e0dcd7;
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .book-cta { margin-top: auto; }

  @media (max-width: 640px) {
    .book-card.featured { flex-direction: column; }
    .book-card.featured .book-cover { min-width: unset; max-width: unset; }
  }
</style>
